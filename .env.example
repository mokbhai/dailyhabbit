# Frontend (build-time for Astro)
PUBLIC_API_URL=http://localhost:3001

# web-host runtime (docker-compose sets PORT=4321 on the web-host service)
WEB_PORT=4321
HOST=0.0.0.0
PRIMARY_FRONTEND=web

# api runtime (NestJS dev + docker api service)
PORT=3001
CORS_ORIGIN=http://localhost:4321,http://127.0.0.1:4321
# SQLite path is relative to packages/db/prisma/schema.prisma
DATABASE_URL=file:../../../data/dev.db
# Production libSQL (e.g. Turso) — uncomment and set DATABASE_AUTH_TOKEN when deploying
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=
JWT_SECRET=dev-secret-change-in-production
UPLOAD_DIR=data/uploads
MAX_UPLOAD_BYTES=10485760
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=60000
GUIDANCE_RATE_LIMIT_MAX=20
GUIDANCE_RATE_LIMIT_WINDOW_MS=600000
UPLOAD_RATE_LIMIT_MAX=30
UPLOAD_RATE_LIMIT_WINDOW_MS=60000

# OpenAI (api only — never PUBLIC_*)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_VISION_MODEL=gpt-4o-mini

# WhatsApp / Evolution API (api only)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
