---
const checkpoints = [
  'Built as a separate Astro app',
  'Mounted below /secondary',
  'Served by the shared Node host',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Secondary Astro app for validating the shared Node web host deployment strategy."
    />
    <title>Secondary Astro App</title>
    <style>
      :root {
        color-scheme: light;
        font-family:
          Inter,
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          'Segoe UI',
          sans-serif;
        background: #f6f7f9;
        color: #17202a;
      }

      body {
        margin: 0;
      }

      main {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 48px 20px;
      }

      section {
        width: min(720px, 100%);
        border: 1px solid #d9dee7;
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 24px 70px rgb(30 42 59 / 12%);
        overflow: hidden;
      }

      header {
        display: grid;
        gap: 16px;
        padding: 40px;
        border-bottom: 1px solid #e8ebf1;
      }

      .mark {
        width: 56px;
        aspect-ratio: 1;
        display: grid;
        place-items: center;
        border-radius: 8px;
        background: #153b7d;
        color: #ffffff;
        font-weight: 800;
      }

      h1 {
        margin: 0;
        font-size: 2.25rem;
        line-height: 1.05;
      }

      p {
        margin: 0;
        color: #516070;
        font-size: 1rem;
        line-height: 1.7;
      }

      ul {
        display: grid;
        gap: 12px;
        margin: 0;
        padding: 28px 40px 40px;
        list-style: none;
      }

      li {
        display: flex;
        align-items: center;
        gap: 12px;
        color: #243244;
      }

      li::before {
        content: '';
        width: 10px;
        aspect-ratio: 1;
        border-radius: 50%;
        background: #0f9f6e;
        flex: none;
      }
    </style>
  </head>
  <body>
    <main>
      <section aria-labelledby="page-title">
        <header>
          <div class="mark" aria-hidden="true">A2</div>
          <h1 id="page-title">Secondary Astro App</h1>
          <p>
            This page is generated by a second Astro workspace and served from
            the same Node process as the primary web app.
          </p>
        </header>
        <ul>
          {
            checkpoints.map((checkpoint) => (
              <li>
                <span>{checkpoint}</span>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
  </body>
</html>
