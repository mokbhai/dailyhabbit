---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'DRCODE 75 HARD CHALLENGE', description = '75 days. 5 tasks. No exceptions.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body
    class="min-h-screen bg-[var(--bg-black)] text-[var(--text-primary)] antialiased"
    style="font-family: var(--font-body);"
  >
    <slot />
  </body>
</html>
