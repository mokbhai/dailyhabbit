---
import { getRelativeLocaleUrl } from 'astro:i18n';

import {
  featureItems,
  homeBlueprint,
  homePackages,
  pipelineStages,
  quickstartItems,
} from '../../content/home';
import type { Locale } from '../../i18n/config';
import { getTranslations } from '../../i18n/messages';
import { HeroGraph } from './HeroGraph';
import { CopyCommandButton } from './CopyCommandButton';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale, 'home');
const nextLocale: Locale = locale === 'en' ? 'de' : 'en';
const [wordmarkPrefix, wordmarkSuffix = ''] = t('wordmark').split('/');
---

<div class="home-shell">
  <div class="container">
    <nav>
      <div class="nav-wordmark">
        {wordmarkPrefix}<span class="slash">/</span>{wordmarkSuffix}
      </div>
      <ul class="nav-center">
        <li><a href="#architecture">{t('nav.architecture')}</a></li>
        <li><a href="#pipeline">{t('nav.pipeline')}</a></li>
        <li><a href="#features">{t('nav.features')}</a></li>
        <li><a href="#quickstart">{t('nav.quickstart')}</a></li>
      </ul>
      <div class="nav-right">
        <a class="nav-lang" href={getRelativeLocaleUrl(nextLocale, '')}
          >{t('langLabel')}</a
        >
        <span class="nav-version">{t('version')}</span>
        <a href="#" class="nav-gh" aria-label={t('nav.github')}>
          <svg viewBox="0 0 16 16"
            ><path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
            ></path></svg
          >
        </a>
      </div>
    </nav>
  </div>

  <div class="container">
    <section class="hero">
      <div class="hero-content">
        <div class="hero-eyebrow">{t('hero.eyebrow')}</div>
        <h1>
          {t('hero.title.line1')}<br />
          {t('hero.title.line2Lead')}
          <em>{t('hero.title.accent')}</em><br />
          {t('hero.title.line3')}
        </h1>
        <p class="hero-sub">{t('hero.body')}</p>
        <div class="hero-actions">
          <a href="#quickstart" class="btn-clone">{t('hero.primary')}</a>
          <a href="#architecture" class="btn-explore">{t('hero.secondary')}</a>
        </div>
        <div class="hero-cmd">
          <code>{t('hero.command')}</code>
          <CopyCommandButton
            command={t('hero.command')}
            idleLabel={t('hero.copyIdle')}
            doneLabel={t('hero.copyDone')}
            client:load
          />
        </div>
      </div>
      <div class="hero-graph-wrap">
        <div class="hero-graph-shell">
          <HeroGraph client:load />
        </div>
        <div class="hero-fade-bottom"></div>
      </div>
    </section>
  </div>

  <div class="container" id="architecture">
    <section class="section reveal">
      <div class="section-header">
        <div class="section-num">{t('architecture.number')}</div>
        <div class="section-title">{t('architecture.title')}</div>
        <p class="section-desc">{t('architecture.description')}</p>
      </div>
      <div class="arch-layout">
        <div class="blueprint">
          <div class="blueprint-title">{t('architecture.blueprintTitle')}</div>
          {
            homeBlueprint.map((item, index) => (
              <>
                <div
                  class:list={[
                    'bp-row',
                    'dir' in item && item.dir && 'dir',
                    item.level === 1 && 'l1',
                  ]}
                >
                  <span class:list={['bp-dot', item.color]} />
                  {item.label}
                </div>
                {index === 6 && <div class="bp-sep" />}
              </>
            ))
          }
        </div>
        <div class="pkg-list">
          {
            homePackages.map((item) => (
              <div class:list={['pkg-item', `pkg-${item.tone}`]}>
                <div class="pkg-item-header">
                  <span class="pkg-item-dot" />
                  <h3>{item.title}</h3>
                  <span class="pkg-item-path">
                    {t(`packages.${item.id}.path`)}
                  </span>
                </div>
                <p>{t(`packages.${item.id}.body`)}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </div>

  <div class="container" id="pipeline">
    <section class="section reveal">
      <div class="section-header">
        <div class="section-num">{t('pipeline.number')}</div>
        <div class="section-title">{t('pipeline.title')}</div>
        <p class="section-desc">{t('pipeline.description')}</p>
      </div>
      <div class="pipeline-track">
        {
          pipelineStages.map((stage) => (
            <div class="pipe-stage">
              <div class="pipe-icon">{stage.icon}</div>
              <h4>{t(`pipeline.stages.${stage.id}`)}</h4>
              <p>{stage.command}</p>
              <div class="pipe-arrow" />
            </div>
          ))
        }
      </div>
    </section>
  </div>

  <div class="container" id="features">
    <section class="section reveal">
      <div class="section-header">
        <div class="section-num">{t('features.number')}</div>
        <div class="section-title">
          {t('features.title')}<br />{t('features.titleBreak')}
        </div>
        <p class="section-desc">{t('features.description')}</p>
      </div>
      <div class="feat-grid">
        {
          featureItems.map((item, index) => (
            <div class="feat-card">
              <div class="feat-num">{String(index + 1).padStart(2, '0')}</div>
              <h3>{t(`features.items.${item}.title`)}</h3>
              <p>{t(`features.items.${item}.body`)}</p>
            </div>
          ))
        }
      </div>
    </section>
  </div>

  <div class="container" id="quickstart">
    <section class="section reveal">
      <div class="section-header">
        <div class="section-num">{t('quickstart.number')}</div>
        <div class="section-title">{t('quickstart.title')}</div>
        <p class="section-desc">{t('quickstart.description')}</p>
      </div>
      <div class="qs-track">
        {
          quickstartItems.map((item) => (
            <div class="qs-card">
              <h4>{t(`quickstart.items.${item.id}.title`)}</h4>
              <p>{t(`quickstart.items.${item.id}.body`)}</p>
              <div class="qs-cmd">
                <span class="dollar">$</span>
                {item.command}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </div>

  <div class="container">
    <section class="cta-band reveal">
      <div class="cta-band-title">
        {t('cta.title.line1')}<br />
        {t('cta.title.line2Lead')}
        <em>{t('cta.title.accent')}</em>{t('cta.title.suffix')}
      </div>
      <p>{t('cta.body')}</p>
      <a href="#quickstart" class="btn-clone cta-button">{t('cta.action')}</a>
    </section>
  </div>

  <div class="container">
    <footer>
      <div class="footer-inner">
        <div class="footer-left">{t('footer.license')}</div>
        <ul class="footer-links">
          <li><a href="#">{t('nav.github')}</a></li>
          <li><a href="#">{t('nav.docs')}</a></li>
          <li><a href="#">{t('nav.discord')}</a></li>
          <li><a href="#">{t('nav.changelog')}</a></li>
        </ul>
      </div>
    </footer>
  </div>
</div>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' },
  );

  document
    .querySelectorAll('.reveal')
    .forEach((element) => observer.observe(element));
</script>

<style is:global>
  :root {
    --cream: #f8f5f0;
    --warm-white: #fdfcfa;
    --sand: #ede8e0;
    --ink: #1a1816;
    --ink-light: #3d3a36;
    --ink-muted: #7a7570;
    --ink-faint: #b0aaa2;
    --ink-ghost: #d5d0c9;
    --teal: #2a7c6f;
    --teal-light: #3ba392;
    --teal-wash: rgba(42, 124, 111, 0.06);
    --teal-wash-strong: rgba(42, 124, 111, 0.12);
    --coral: #d4654a;
    --amber: #c4922a;
    --indigo: #5b6abf;
    --display: 'Playfair Display', Georgia, serif;
    --mono: 'Source Code Pro', monospace;
    --body: 'Libre Franklin', sans-serif;
    --radius: 12px;
  }

  .home-shell {
    background: var(--cream);
    color: var(--ink);
    font-family: var(--body);
    line-height: 1.65;
    overflow-x: hidden;
  }

  .home-shell::before {
    content: '';
    position: fixed;
    inset: 0;
    opacity: 0.35;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 999;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 40px;
  }

  nav {
    padding: 28px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    animation: fadeIn 0.8s ease both;
  }

  .nav-wordmark {
    font-family: var(--mono);
    font-weight: 600;
    font-size: 17px;
    color: var(--ink);
    letter-spacing: -0.3px;
  }

  .nav-wordmark .slash {
    color: var(--ink-faint);
    margin: 0 1px;
  }

  .nav-center {
    display: flex;
    gap: 36px;
    list-style: none;
  }

  .nav-center a,
  .nav-lang,
  .footer-links a {
    font-family: var(--body);
    font-size: 14px;
    font-weight: 400;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.25s;
    position: relative;
  }

  .nav-center a::after,
  .nav-lang::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--teal);
    transition: width 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .nav-center a:hover,
  .nav-lang:hover,
  .footer-links a:hover {
    color: var(--ink);
  }

  .nav-center a:hover::after,
  .nav-lang:hover::after {
    width: 100%;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav-version {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--ink-faint);
    padding: 4px 12px;
    border: 1px solid var(--ink-ghost);
    border-radius: 100px;
  }

  .nav-gh {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
    text-decoration: none;
  }

  .nav-gh:hover {
    transform: scale(1.08);
    box-shadow: 0 4px 16px rgba(26, 24, 22, 0.15);
  }

  .nav-gh svg {
    fill: var(--cream);
    width: 18px;
    height: 18px;
  }

  .hero {
    padding: 80px 0 0;
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
  }

  .hero-content {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    animation: riseUp 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.15s;
  }

  .hero-eyebrow {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .hero-eyebrow::before,
  .hero-eyebrow::after {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--teal);
    opacity: 0.4;
  }

  h1 {
    font-family: var(--display);
    font-weight: 400;
    font-size: 72px;
    line-height: 1.08;
    letter-spacing: -2px;
    color: var(--ink);
    margin-bottom: 28px;
  }

  h1 em,
  .cta-band-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--teal);
  }

  .hero-sub {
    font-size: 18px;
    font-weight: 300;
    color: var(--ink-muted);
    max-width: 520px;
    margin: 0 auto 44px;
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    margin-bottom: 20px;
  }

  .btn-clone,
  .btn-explore,
  .hero-copy-button {
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .btn-clone {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 500;
    padding: 15px 32px;
    background: var(--ink);
    color: var(--cream);
    border: none;
    border-radius: 100px;
    box-shadow: 0 2px 8px rgba(26, 24, 22, 0.12);
  }

  .btn-clone:hover {
    background: var(--teal);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(42, 124, 111, 0.2);
  }

  .btn-explore {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--body);
    font-size: 14px;
    font-weight: 500;
    padding: 15px 28px;
    background: transparent;
    color: var(--ink-muted);
    border: 1.5px solid var(--ink-ghost);
    border-radius: 100px;
  }

  .btn-explore:hover {
    border-color: var(--ink-muted);
    color: var(--ink);
  }

  .hero-cmd {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ink-faint);
    margin-top: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .hero-cmd code,
  .hero-copy-button {
    border-radius: 8px;
    border: 1px solid var(--sand);
  }

  .hero-cmd code {
    background: var(--sand);
    padding: 6px 16px;
    color: var(--ink-muted);
    user-select: all;
  }

  .hero-copy-button {
    background: var(--warm-white);
    color: var(--ink-muted);
    font-family: var(--mono);
    font-size: 12px;
    padding: 6px 12px;
  }

  .hero-copy-button:hover {
    background: var(--teal-wash-strong);
    border-color: rgba(42, 124, 111, 0.18);
    color: var(--teal);
  }

  .hero-graph-wrap {
    flex: 1;
    position: relative;
    margin-top: 40px;
    min-height: 480px;
  }

  .hero-graph-shell {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    background:
      radial-gradient(
        circle at center,
        rgba(255, 255, 255, 0.72),
        rgba(248, 245, 240, 0) 58%
      ),
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.14),
        rgba(248, 245, 240, 0)
      );
    filter: saturate(0.96);
    animation: graphAppear 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.45s;
  }

  #graphCanvas {
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
    z-index: 1;
    display: block;
  }

  .hero-graph-root {
    position: absolute;
    inset: 0;
  }

  .hero-fade-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 160px;
    background: linear-gradient(to bottom, transparent, var(--cream));
    z-index: 2;
    pointer-events: none;
  }

  .section {
    padding: 100px 0;
  }

  .section-header {
    max-width: 560px;
    margin-bottom: 64px;
  }

  .section-num {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--teal);
    font-weight: 500;
    letter-spacing: 1px;
    margin-bottom: 14px;
  }

  .section-title,
  .cta-band-title {
    font-family: var(--display);
    font-size: 44px;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -1px;
  }

  .section-desc {
    font-size: 16px;
    font-weight: 300;
    color: var(--ink-muted);
    line-height: 1.7;
  }

  .arch-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .blueprint,
  .pkg-item,
  .pipeline-track,
  .feat-card,
  .qs-card {
    background: var(--warm-white);
    border: 1px solid var(--sand);
    border-radius: var(--radius);
  }

  .blueprint {
    padding: 32px;
    position: sticky;
    top: 40px;
    box-shadow: 0 1px 3px rgba(26, 24, 22, 0.04);
  }

  .blueprint-title {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--ink-faint);
    padding-bottom: 16px;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--sand);
  }

  .bp-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 8px;
    font-family: var(--mono);
    font-size: 13.5px;
    color: var(--ink-muted);
    border-radius: 6px;
    margin: 0 -8px;
    transition:
      color 0.2s,
      background 0.2s;
  }

  .bp-row:hover {
    color: var(--ink);
    background: var(--teal-wash);
  }

  .bp-row.dir {
    font-weight: 500;
    color: var(--ink-light);
  }

  .bp-row.l1 {
    padding-left: 28px;
  }

  .bp-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .bp-dot.teal {
    background: var(--teal);
  }

  .bp-dot.coral {
    background: var(--coral);
  }

  .bp-dot.amber {
    background: var(--amber);
  }

  .bp-dot.indigo {
    background: var(--indigo);
  }

  .bp-dot.ghost {
    background: var(--ink-ghost);
  }

  .bp-sep {
    height: 1px;
    background: var(--sand);
    margin: 12px 0;
  }

  .pkg-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pkg-item {
    padding: 28px 32px;
    transition: all 0.35s cubic-bezier(0.25, 1, 0.5, 1);
    position: relative;
    overflow: hidden;
  }

  .pkg-item::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--pkg-color, var(--teal));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .pkg-item:hover {
    border-color: var(--ink-ghost);
    transform: translateX(4px);
    box-shadow: 0 8px 32px rgba(26, 24, 22, 0.06);
  }

  .pkg-item:hover::after {
    opacity: 1;
  }

  .pkg-item-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 10px;
  }

  .pkg-item-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--pkg-color, var(--teal));
    flex-shrink: 0;
  }

  .pkg-item h3,
  .feat-card h3,
  .qs-card h4,
  .pipe-stage h4 {
    font-family: var(--mono);
    font-weight: 600;
    color: var(--ink);
  }

  .pkg-item h3 {
    font-size: 15px;
  }

  .pkg-item-path {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-faint);
    margin-left: auto;
  }

  .pkg-item p,
  .feat-card p,
  .qs-card p {
    font-size: 14px;
    color: var(--ink-muted);
    line-height: 1.65;
  }

  .pkg-item p {
    padding-left: 24px;
  }

  .pkg-teal {
    --pkg-color: var(--teal);
  }

  .pkg-coral {
    --pkg-color: var(--coral);
  }

  .pkg-indigo {
    --pkg-color: var(--indigo);
  }

  .pkg-amber {
    --pkg-color: var(--amber);
  }

  .pipeline-track {
    display: flex;
    align-items: stretch;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(26, 24, 22, 0.04);
  }

  .pipe-stage {
    flex: 1;
    padding: 40px 28px;
    text-align: center;
    border-right: 1px solid var(--sand);
    position: relative;
    transition: background 0.3s;
  }

