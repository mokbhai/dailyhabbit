generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ActivityKind {
  CHECKBOX
  NUMBER
  TIERED
  SUBPOINTS
}

enum MemberStatus {
  ACTIVE
  ELIMINATED
  COMPLETED
}

model User {
  id           String        @id @default(cuid())
  name         String
  phone        String?       @unique
  email        String?       @unique
  passwordHash String
  timezone     String        @default("UTC")
  avatarUrl    String?
  groupId      String?
  group        Group?        @relation(fields: [groupId], references: [id])
  reminderTime  String?
  whatsappOptIn Boolean       @default(true)
  createdAt     DateTime      @default(now())
  challenges     Challenge[]
  activityLogs   ActivityLog[]
  reminderLogs   ReminderLog[]
  adminOf        Group[]       @relation("GroupAdmin")
}

model ReminderLog {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id])
  date   DateTime
  kind   String
  sentAt DateTime @default(now())
  status String

  @@unique([userId, date, kind])
  @@index([userId, date])
}

model Group {
  id          String     @id @default(cuid())
  name        String
  inviteToken String     @unique
  adminUserId String
  admin       User       @relation("GroupAdmin", fields: [adminUserId], references: [id])
  members     User[]
  dayLabels   DayLabel[]
  activities  Activity[]
  createdAt   DateTime   @default(now())
}

model Challenge {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  groupId       String?
  startDate     DateTime
  endDate       DateTime?
  // Legacy fallback only — the API always sets this explicitly to
  // DEFAULT_CHALLENGE_LENGTH_DAYS (75) on create. See utils/challenge-query.ts.
  lengthDays    Int           @default(30)
  currentDay    Int           @default(1)
  isActive      Boolean       @default(true)
  totalXp       Int           @default(0)
  currentStreak Int           @default(0)
  longestStreak Int           @default(0)
  activityLogs  ActivityLog[]
  dayScores     DayScore[]
}

model Activity {
  id               String        @id @default(cuid())
  groupId          String?
  group            Group?        @relation(fields: [groupId], references: [id])
  ownerUserId      String?
  seedKey          String?
  title            String
  emoji            String?
  kind             ActivityKind
  scored           Boolean       @default(true)
  isPersonal       Boolean       @default(false)
  xpComplete       Int?
  xpMiss           Int?
  unitLabel        String?
  xpPerUnit        Float?
  xpCap            Int?
  missXp           Int?
  subPoints        Json?
  tiers            Json?
  deductMultiplier Float         @default(2)
  sortOrder        Int           @default(0)
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  logs             ActivityLog[]

  @@unique([groupId, seedKey])
  @@index([groupId])
  @@index([ownerUserId])
}

model ActivityLog {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  activityId  String
  activity    Activity  @relation(fields: [activityId], references: [id])
  date        DateTime
  value       Float?
  tier        String?
  subPoints   Json?
  state       String?
  xpAwarded   Int       @default(0)
  proofUrl    String?
  aiVerdict   String?

  @@unique([challengeId, activityId, date])
  @@index([userId, activityId, date])
}

model DayScore {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id])
  userId      String
  date        DateTime
  dayNumber   Int
  xpEarned    Int       @default(0)
  xpDeducted  Int       @default(0)
  netXp       Int       @default(0)
  personalXp  Int       @default(0)
  breakdown   Json
  finalized   Boolean   @default(false)

  @@unique([challengeId, date])
  @@index([userId, date])
}

model DayLabel {
  id          String   @id @default(cuid())
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id])
  dayNumber   Int
  labelText   String
  setByUserId String
  updatedAt   DateTime @updatedAt

  @@unique([groupId, dayNumber])
}
